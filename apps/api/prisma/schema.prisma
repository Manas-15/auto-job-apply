// Auto Job Apply — data model
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  // "native" for local dev; the debian target is for the Docker runtime image.
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// User & profile
// ─────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  profile      Profile?
  resumes      Resume[]
  applications Application[]
  coverLetters CoverLetter[]
  preference   JobPreference?
}

// Personal info used to fill application forms and tailor documents.
model Profile {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  phone             String?
  linkedinUrl       String?
  githubUrl         String?
  portfolioUrl      String?
  currentLocation   String?
  preferredLocations String[] @default([])
  noticePeriodDays  Int?
  currentCtc        String?
  expectedCtc       String?
  yearsExperience   Float?

  // Free-form answers to recurring application questions
  // e.g. { "willingToRelocate": "Yes", "needsSponsorship": "No" }
  commonAnswers     Json     @default("{}")

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────
// Resumes
// ─────────────────────────────────────────────────────────────

model Resume {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  label        String   // e.g. "Master", "React + Next", "Senior Frontend"
  isMaster     Boolean  @default(false)

  // Structured content the AI reads/tailors against.
  content      Json     @default("{}")
  // Plain-text extraction of the resume for prompting & ATS scoring.
  rawText      String?
  // Pointer to the rendered file in storage (local path or S3 key).
  fileKey      String?

  // If this resume was generated by tailoring for a specific job.
  tailoredForJobId String?
  tailoredForJob   Job?  @relation("ResumeTailoredForJob", fields: [tailoredForJobId], references: [id], onDelete: SetNull)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  applications Application[]
  coverLetters CoverLetter[]
  atsScores    AtsScore[]

  @@index([userId])
}

// ─────────────────────────────────────────────────────────────
// Companies, recruiters, jobs
// ─────────────────────────────────────────────────────────────

model Company {
  id          String   @id @default(cuid())
  name        String   @unique
  website     String?
  careersUrl  String?
  createdAt   DateTime @default(now())

  jobs        Job[]
  recruiters  Recruiter[]
}

model Recruiter {
  id          String   @id @default(cuid())
  name        String?
  email       String?
  linkedinUrl String?
  companyId   String?
  company     Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())

  jobs        Job[]
}

enum JobSource {
  LINKEDIN
  NAUKRI
  INDEED
  INSTAHYRE
  WELLFOUND
  COMPANY_CAREERS
  OTHER
}

enum WorkMode {
  REMOTE
  HYBRID
  ONSITE
  UNKNOWN
}

enum ApplyMethod {
  FORM
  EMAIL
  LINKEDIN_EASY_APPLY
  EXTERNAL
  UNKNOWN
}

model Job {
  id            String    @id @default(cuid())
  source        JobSource @default(OTHER)
  // Stable identifier from the source to dedupe re-scrapes.
  externalId    String?
  url           String?

  title         String
  companyId     String?
  company       Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  recruiterId   String?
  recruiter     Recruiter? @relation(fields: [recruiterId], references: [id], onDelete: SetNull)

  location      String?
  workMode      WorkMode  @default(UNKNOWN)
  salaryText    String?
  applyMethod   ApplyMethod @default(UNKNOWN)
  hrEmail       String?

  descriptionRaw String?

  // Filled by the AI Job Analyzer (Module 2).
  analysis      JobAnalysis?

  postedAt      DateTime?
  scrapedAt     DateTime  @default(now())

  applications  Application[]
  atsScores     AtsScore[]
  coverLetters  CoverLetter[]
  tailoredResumes Resume[] @relation("ResumeTailoredForJob")

  @@unique([source, externalId])
  @@index([title])
}

// Structured JD extraction (Module 2).
model JobAnalysis {
  id                String   @id @default(cuid())
  jobId             String   @unique
  job               Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  requiredSkills    String[] @default([])
  niceToHaveSkills  String[] @default([])
  atsKeywords       String[] @default([])
  responsibilities  String[] @default([])
  minYears          Float?
  maxYears          Float?
  seniority         String?
  extractedLocation String?
  extractedSalary   String?
  summary           String?

  model             String?  // which AI model produced this
  createdAt         DateTime @default(now())
}

// ─────────────────────────────────────────────────────────────
// ATS scoring (Module 4)
// ─────────────────────────────────────────────────────────────

model AtsScore {
  id            String   @id @default(cuid())
  jobId         String
  job           Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  resumeId      String
  resume        Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  score         Int      // 0-100
  matchedKeywords String[] @default([])
  missingKeywords String[] @default([])
  notes         String?

  createdAt     DateTime @default(now())

  @@index([jobId])
  @@index([resumeId])
}

// ─────────────────────────────────────────────────────────────
// Cover letters (Module 5)
// ─────────────────────────────────────────────────────────────

model CoverLetter {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  resumeId  String?
  resume    Resume?  @relation(fields: [resumeId], references: [id], onDelete: SetNull)

  content   String
  fileKey   String?
  model     String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([jobId])
}

// ─────────────────────────────────────────────────────────────
// Applications (Modules 6/7/8) + status tracking (Module 9)
// ─────────────────────────────────────────────────────────────

enum ApplicationStatus {
  MATCHED          // scored, awaiting decision
  QUEUED           // scheduled to apply
  NEEDS_APPROVAL   // form filled, paused for user confirmation
  SUBMITTED
  REJECTED
  INTERVIEW
  OFFER
  SKIPPED
  FAILED
}

model Application {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId       String
  job         Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  resumeId    String?
  resume      Resume?  @relation(fields: [resumeId], references: [id], onDelete: SetNull)

  status      ApplicationStatus @default(MATCHED)
  matchScore  Int?     // ATS/match score at time of decision
  method      ApplyMethod @default(UNKNOWN)

  // Whatever the automation captured / needs (screenshots, field map, errors).
  meta        Json     @default("{}")
  submittedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  events      ApplicationEvent[]
  interviews  Interview[]

  @@unique([userId, jobId])
  @@index([status])
}

model ApplicationEvent {
  id            String   @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  type          String   // e.g. "created", "form_filled", "submitted", "error"
  message       String?
  data          Json     @default("{}")
  createdAt     DateTime @default(now())

  @@index([applicationId])
}

model Interview {
  id            String   @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  round         String?
  scheduledAt   DateTime?
  notes         String?
  createdAt     DateTime @default(now())
}

// ─────────────────────────────────────────────────────────────
// Job preferences (drives the Job Finder & scoring)
// ─────────────────────────────────────────────────────────────

model JobPreference {
  id                 String   @id @default(cuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  titles             String[] @default([]) // ["React Developer", "Frontend Developer"]
  skills             String[] @default([])
  minSalary          Int?
  workModes          WorkMode[] @default([])
  cities             String[] @default([])
  prioritizeCompanies String[] @default([])
  avoidCompanies     String[] @default([])
  sources            JobSource[] @default([])

  // Score thresholds for the auto/approve/skip gate.
  autoApplyThreshold Int      @default(95)
  approveThreshold   Int      @default(80)

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}
