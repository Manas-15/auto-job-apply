# Production env for docker-compose.prod.yml.
# Copy to .env.prod and fill in. Postgres/Redis run inside the compose network,
# so you usually only need the AI key + a strong JWT secret.

# Strong random string (e.g. `openssl rand -hex 32`)
JWT_SECRET=

# AI provider + key (free: gemini or ollama). See .env.example for options.
AI_PROVIDER=gemini
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# CORS: "*" is fine for a single-owner box; set to your real frontend URL
# (e.g. https://jobs.example.com) for a public deployment.
CORS_ORIGINS=*

# Frontend → backend URL baked at build time. Leave empty to auto-target
# <host>:4000 from the browser; set to a public URL when using a domain.
NEXT_PUBLIC_API_URL=

# Optional: enable the free-source scheduler (BullMQ)
JOB_FINDER_ENABLED=false

# Optional: override the default Postgres password
POSTGRES_PASSWORD=aja
