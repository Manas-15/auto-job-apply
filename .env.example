# ─────────────────────────────────────────────────────────────
# Auto Job Apply — environment configuration
# Copy to .env and fill in. Everything here has a sane default
# for local development; you can run the whole stack for free.
# ─────────────────────────────────────────────────────────────

NODE_ENV=development
API_PORT=4000
# Comma-separated list of allowed CORS origins for the web dashboard
CORS_ORIGINS=http://localhost:3000

# ── Database (Postgres) ──────────────────────────────────────
# Matches docker-compose.yml defaults.
DATABASE_URL=postgresql://aja:aja@localhost:5432/auto_job_apply?schema=public

# ── Redis (BullMQ queues) ────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ─────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# ── AI provider ──────────────────────────────────────────────
# Which provider the AI abstraction uses by default.
# Options: gemini | ollama | openai | anthropic
AI_PROVIDER=gemini

# Gemini (free tier available): https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Ollama (fully local, free): https://ollama.com
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# OpenAI (paid)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic / Claude (paid)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# ── Storage ──────────────────────────────────────────────────
# local | s3
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./storage

# S3 (only if STORAGE_DRIVER=s3)
S3_BUCKET=
S3_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Notifications ────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Application engine ───────────────────────────────────────
# Global safety switch. When true, the engine fills forms but never
# clicks final submit — it pauses for your one-click approval.
AUTO_SUBMIT=false
# Run Playwright headed (visible) for debugging.
PLAYWRIGHT_HEADLESS=true
