# ─────────────────────────────────────────────────────────────
# AI Resume Builder & ATS Optimizer — environment configuration
# Copy to .env and fill in. Local defaults match docker-compose.yml.
# ─────────────────────────────────────────────────────────────

NODE_ENV=development

# ── Database (Postgres) ──────────────────────────────────────
# Matches docker-compose.yml. On Vercel, point this at Supabase.
DATABASE_URL=postgresql://aja:aja@localhost:5432/resume_builder?schema=public

# ── Auth (email/password JWT) ────────────────────────────────
# Generate a strong secret for production, e.g. `openssl rand -base64 32`
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# ── AI provider ──────────────────────────────────────────────
# gemini (MVP, free tier) | openai (optional)
AI_PROVIDER=gemini

# Gemini — get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest

# OpenAI (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
